---
import IndexedTitle from "../../components/IndexedTitle.astro";
import { experiences } from "../../data/data";

const lastIndex = experiences.length - 1;
---

<section class="py-32" id="experience">
  <IndexedTitle index="02">Experience</IndexedTitle>

  <div class="max-w-5xl mx-auto flex flex-col mt-16 px-4">
    {
      experiences.map((job, index) => {
        const parts = job.timeline.split('·');
        const dates = parts[0]?.trim() || job.timeline;
        const duration = parts[1]?.trim() || '';
        const isLast = index === lastIndex;
        const isEven = index % 2 === 0;

        return (
          <div class={`group relative flex w-full ${isEven ? 'flex-row' : 'flex-row-reverse'}`}>
            
            <!-- Side 1: Date -->
            <div class={`w-1/2 pt-0.5 ${isEven ? 'text-right pr-5 sm:pr-12' : 'text-left pl-5 sm:pl-12'}`}>
              <p class="text-sm font-bold tracking-widest text-dim uppercase group-hover:text-bright transition-colors duration-300">
                {dates}
              </p>
              {duration && (
                <p class="text-[11px] sm:text-xs font-semibold text-dim/40 mt-1 uppercase tracking-wide">
                  {duration}
                </p>
              )}
            </div>

            <!-- Timeline Rail -->
            <div class="flex flex-col items-center shrink-0 mt-1.5">
              <!-- Node -->
              <div class="relative z-10 h-3.5 w-3.5 rounded-full bg-white/20 group-hover:bg-bright transition-all duration-300 group-hover:scale-110 shadow-[0_0_0_4px_#161211]"></div>
              <!-- Stem -->
              {!isLast && (
                <div class="w-[2px] flex-1 bg-white/10 mt-1 -mb-2 group-hover:bg-white/20 transition-colors duration-300"></div>
              )}
            </div>

            <!-- Side 2: Content -->
            <div class={`w-1/2 pb-16 sm:pb-24 -mt-1 ${isEven ? 'text-left pl-5 sm:pl-12' : 'text-right pr-5 sm:pr-12'}`}>
              <h3 class="text-lg sm:text-xl font-bold text-white transition-colors duration-300 group-hover:text-bright">
                {job.role}
              </h3>
              <h4 class="text-sm sm:text-base font-semibold text-white/60 mt-1">
                {job.company}
              </h4>
              
              <div class={`mt-5 flex flex-wrap gap-2 sm:gap-2.5 ${isEven ? 'justify-start' : 'justify-end'}`}>
                <span class="inline-flex items-center rounded-sm bg-secondary px-2.5 py-1 text-[10px] sm:text-xs font-bold uppercase tracking-wider text-bright">
                  {job.employment}
                </span>
                <span class="inline-flex items-center rounded-sm bg-secondary px-2.5 py-1 text-[10px] sm:text-xs font-bold uppercase tracking-wider text-bright">
                  {job.workMode}
                </span>
                <span class="inline-flex items-center rounded-sm bg-secondary px-2.5 py-1 text-[10px] sm:text-xs font-bold uppercase tracking-wider text-bright">
                  {job.location}
                </span>
              </div>
            </div>

          </div>
        );
      })
    }
  </div>
</section>
