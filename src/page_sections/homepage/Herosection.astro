---
import HoverButton from "../../components/HoverButton.astro";
---

<section class="w-full flex items-center">
  <div>
    <p class="text-bright">Hi, I am</p>
    <h1 class="text-4xl md:text-6xl font-extrabold leading-relaxed">
      Kethan Krishna P K.
    </h1>
    <p class="text-xl md:text-2xl font-extrabold max-w-5xl text-dim">
      AI engineering, building systems that ships.
    </p>
    <p class="text-dim tracking-normal md:tracking-widest max-w-xl mt-5">
      I engineer LLM systems built for production—reliable, typed, and
      deployable. My focus spans audio ML and multimodal models, with the
      infrastructure depth to see them through to scale.
    </p>
    <div class="mt-10 mb-10 md:mb-0">
      <a href="mailto:kethankrkofficial@gmail.com">
        <HoverButton paddingX="15" paddingY="25"
          >Let's talk business</HoverButton
        >
      </a>
    </div>
  </div>
</section>

<style>
  section {
    min-height: calc(100vh - 100px);
  }
</style>
